PORT=5000
MONGO_URI=mongodb://localhost:27017/womens-safety-tracker
JWT_SECRET=change-this-secret

TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

SMS_PROVIDER=twilio
MSG91_AUTH_KEY=your_msg91_auth_key
MSG91_TEMPLATE_ID=your_msg91_template_id
MSG91_SENDER_ID=SOSALT

FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_CLIENT_EMAIL=your_firebase_service_account_client_email
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nreplace_with_service_account_private_key\n-----END PRIVATE KEY-----\n"

# Optional legacy fallback only if your Firebase project still supports the old API.
FCM_SERVER_KEY=your_legacy_firebase_cloud_messaging_server_key

# Optional fallback receiver. SOS also sends to contacts added inside the app.
SOS_NOTIFICATION_PHONE=+919876543210
